{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "cargo",
			"command": "build",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Test",
			"command": "./test.sh",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "test",
				"isDefault": true
			}
		}
	],
	"inputs": [
		{
			"id": "Executable",
			"type": "pickString",
			"description": "Transit system to build",
			"options": [
				"wmata"
			],
			"default": "wmata"
		}
	]
}